# Gbubemi Attah — example environment.
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.
#   cp .env.example .env.local
#
# The site runs fully on local fallback content WITHOUT any of these set.
# Add the Sanity values to power the embedded Studio (/studio) and live editing.

# --- Public Sanity config (safe to expose to the browser) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Canonical site URL — used for canonical links, OG/Twitter URLs and the sitemap.
NEXT_PUBLIC_SITE_URL=https://gbubemi.dev

# --- Server-only secrets (do NOT prefix with NEXT_PUBLIC_) ---
# Read token — only required for private datasets. If unset, public reads use the CDN.
SANITY_API_READ_TOKEN=
# Sanity write/editor token (mutations; also works for reads).
SANITY_API_WRITE_TOKEN=
